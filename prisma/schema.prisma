generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model Campaign {
    id             String          @id @default(cuid())
    name           String
    slug           String          @unique
    templateSlug   String          @default("gonza-gb-sn-fc")
    locale         String          @default("en")
    currencySymbol String          @default("£")
    currencyCode   String          @default("GBP")
    ctaUrl         String
    logoUrl        String?
    colorPrimary   String          @default("oklch(0.74 0.19 55)")
    colorBg        String          @default("oklch(0.16 0.04 265)")
    isActive       Boolean         @default(true)
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    offers         CampaignOffer[]

    @@index([slug])
    @@index([isActive])
}

model CampaignOffer {
    id         String   @id @default(cuid())
    campaignId String
    campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

    name       String
    imageUrl   String?
    tag        String   @default("1 hr")
    badge      String   @default("TOP")
    amount     Float
    rating     Float    @default(4.9)
    note       String?
    position   Int      @default(0)

    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([campaignId, position])
}

model User {
    id        String   @id @default(cuid())
    username  String   @unique
    email     String?
    password  String
    role      String   @default("user")
    approved  Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ColorPreset {
    id           String   @id @default(cuid())
    name         String
    colorPrimary String
    colorBg      String
    createdAt    DateTime @default(now())
}

model LogoPreset {
    id        String   @id @default(cuid())
    name      String
    imageUrl  String
    createdAt DateTime @default(now())
}

model Conversion {
    id           String   @id @default(cuid())
    price        Float    @default(0)
    offerName    String?
    country      String?
    s1           String?
    s2           String?
    clickId      String?
    conversionId String?
    ip           String?
    receivedAt   DateTime @default(now())

    @@index([receivedAt])
    @@index([s1])
}
