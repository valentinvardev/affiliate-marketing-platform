generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model Campaign {
    id             String          @id @default(cuid())
    name           String
    slug           String          @unique
    templateSlug   String          @default("gonza-gb-sn-fc")
    locale         String          @default("en")
    currencySymbol String          @default("£")
    currencyCode   String          @default("GBP")
    ctaUrl         String
    logoUrl        String?
    colorPrimary   String          @default("oklch(0.74 0.19 55)")
    colorBg        String          @default("oklch(0.16 0.04 265)")
    isActive       Boolean         @default(true)
    ownerId        String?
    owner          User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    offers         CampaignOffer[]

    @@index([slug])
    @@index([isActive])
    @@index([ownerId])
}

model CampaignOffer {
    id         String   @id @default(cuid())
    campaignId String
    campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

    name       String
    imageUrl   String?
    tag        String   @default("1 hr")
    badge      String   @default("TOP")
    amount     Float
    rating     Float    @default(4.9)
    note       String?
    position   Int      @default(0)

    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([campaignId, position])
}

model User {
    id        String   @id @default(cuid())
    username  String   @unique
    email     String?
    password  String
    role      String   @default("user")
    approved  Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    campaigns Campaign[]
    cards     CardOwner[]
    spend     SpendLog[]
}

// Mapea cada VCC de TapRain (id de la card) a su usuario dueño
model CardOwner {
    id        String   @id @default(cuid())
    vccId     String   @unique
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    cardName  String?
    createdAt DateTime @default(now())

    @@index([userId])
}

// Gasto atribuido a un usuario (vcc | interaction | engagement | bc | email | ...)
model SpendLog {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    kind      String
    amount    Float
    ref       String?
    note      String?
    createdAt DateTime @default(now())

    @@index([userId, createdAt])
}

// Reparto de profit: por usuario fuente, filas (beneficiario, %) que suman 100
model RevenueSplit {
    id                String   @id @default(cuid())
    sourceUserId      String
    beneficiaryUserId String
    percent           Float
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    @@unique([sourceUserId, beneficiaryUserId])
    @@index([sourceUserId])
}

model ColorPreset {
    id           String   @id @default(cuid())
    name         String
    colorPrimary String
    colorBg      String
    createdAt    DateTime @default(now())
}

model LogoPreset {
    id        String   @id @default(cuid())
    name      String
    imageUrl  String
    createdAt DateTime @default(now())
}

model OfferConfig {
    id          String    @id @default(cuid())
    offerId     String    @unique
    offerName   String
    whitelisted Boolean   @default(false)
    imageUrl    String?
    notes       String?
    appStackId  String?
    appStack    AppStack? @relation(fields: [appStackId], references: [id], onDelete: SetNull)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([whitelisted])
    @@index([appStackId])
}

model AppStack {
    id        String         @id @default(cuid())
    name      String
    items     AppStackItem[]
    offers    OfferConfig[]
    createdAt DateTime       @default(now())
    updatedAt DateTime       @updatedAt
}

model AppStackItem {
    id       String   @id @default(cuid())
    stackId  String
    stack    AppStack @relation(fields: [stackId], references: [id], onDelete: Cascade)
    name     String
    imageUrl String?
    tag      String   @default("1 hr")
    badge    String   @default("TOP")
    amount   Float
    position Int      @default(0)
    createdAt DateTime @default(now())

    @@index([stackId, position])
}

model AppConfig {
    key       String   @id
    value     String
    updatedAt DateTime @updatedAt
}

model ChatMessage {
    id        String   @id @default(cuid())
    userId    String
    username  String
    text      String
    createdAt DateTime @default(now())

    @@index([createdAt])
}

model Conversion {
    id           String   @id @default(cuid())
    price        Float    @default(0)
    offerName    String?
    country      String?
    s1           String?
    s2           String?
    clickId      String?
    conversionId String?
    ip           String?
    receivedAt   DateTime @default(now())

    @@index([receivedAt])
    @@index([s1])
}
