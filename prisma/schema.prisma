generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model Campaign {
    id             String          @id @default(cuid())
    name           String
    slug           String          @unique
    templateSlug   String          @default("gonza-gb-sn-fc")
    locale         String          @default("en")
    currencySymbol String          @default("£")
    currencyCode   String          @default("GBP")
    ctaUrl         String
    logoUrl        String?
    colorPrimary   String          @default("oklch(0.74 0.19 55)")
    colorBg        String          @default("oklch(0.16 0.04 265)")
    isActive       Boolean         @default(true)
    domain         String?         // root domain en el que se sirve (path-based: <domain>/<slug>)
    fontTitle      String?         // fuente de títulos (Google Font, ej. "Manrope")
    fontBody       String?         // fuente de párrafos (ej. "Inter")
    offerName      String?         // oferta de la que se creó (para la franja de la card)
    offerImage     String?         // logo de la oferta
    ownerId        String?
    owner          User?           @relation(fields: [ownerId], references: [id], onDelete: SetNull)
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    offers         CampaignOffer[]
    domains        LandingDomain[]

    @@index([slug])
    @@index([isActive])
    @@index([ownerId])
}

// Registro de dominios raíz conectados (ej. empfohlen.lat). Path-based:
// <domain>/<slug> sirve la campaña con ese slug. campaignId opcional = campaña
// "home" del dominio (lo que muestra el root `domain/`).
model LandingDomain {
    id         String    @id @default(cuid())
    domain     String    @unique // apex en minúsculas, sin www (ej. "empfohlen.lat")
    campaignId String?
    campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
    createdAt  DateTime  @default(now())

    @@index([campaignId])
}

// Dominios de redirección disponibles (sólo el admin los agrega; ej. "dealdrop.lat").
model RedirectDomain {
    id        String   @id @default(cuid())
    domain    String   @unique // apex en minúsculas, sin www
    createdAt DateTime @default(now())
}

// Redirector (cloaking) en dominio/ruta: ON → rota whitepages, OFF → landing de campaña.
// Varios por dominio vía la ruta (ej. dealdrop.lat/1, dealdrop.lat/caca).
model Redirect {
    id          String   @id @default(cuid())
    domain      String   // uno de RedirectDomain
    path        String   @default("") // ruta tras el dominio: "1", "caca" ("" = raíz)
    createdById String?  // quién lo creó
    cloakOn     Boolean  @default(false)
    whitepages  String[] @default([]) // destinos cuando el cloak está prendido
    targetUrl   String?  // landing de la campaña cuando está apagado
    campaignId  String?  // campaña elegida (referencia para autofill)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@unique([domain, path])
    @@index([domain])
}

model CampaignOffer {
    id         String   @id @default(cuid())
    campaignId String
    campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

    name       String
    imageUrl   String?
    tag        String   @default("1 hr")
    badge      String   @default("TOP")
    amount     Float
    rating     Float    @default(4.9)
    note       String?
    position   Int      @default(0)

    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([campaignId, position])
}

model User {
    id        String   @id @default(cuid())
    username  String   @unique
    email     String?
    password  String
    role      String   @default("user")
    approved  Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    campaigns Campaign[]
    cards     CardOwner[]
    spend     SpendLog[]
}

// Mapea cada VCC de TapRain (id de la card) a su usuario dueño
model CardOwner {
    id         String    @id @default(cuid())
    vccId      String    @unique
    userId     String
    user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    cardName   String?
    campaignId String?
    closedAt   DateTime?
    closedById String?
    createdAt  DateTime  @default(now())

    @@index([userId])
    @@index([campaignId])
}

// Guarda del gasto diario de VCC por usuario (baseline = total acumulado al inicio del día)
model SpendGuard {
    id        String    @id @default(cuid())
    userId    String    @unique
    day       String    // YYYY-MM-DD del baseline
    baseline  Float     @default(0)
    pausedAt  DateTime? // cuándo se auto-pausaron las tarjetas por superar el cap
    updatedAt DateTime  @updatedAt
}

// Gasto atribuido a un usuario (vcc | interaction | engagement | bc | email | ...)
model SpendLog {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    kind      String
    amount    Float
    ref       String?
    note      String?
    createdAt DateTime @default(now())

    @@index([userId, createdAt])
}

// Reparto de profit: por usuario fuente, filas (beneficiario, %) que suman 100
model RevenueSplit {
    id                String   @id @default(cuid())
    sourceUserId      String
    beneficiaryUserId String
    percent           Float
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt

    @@unique([sourceUserId, beneficiaryUserId])
    @@index([sourceUserId])
}

model ColorPreset {
    id           String   @id @default(cuid())
    name         String
    colorPrimary String
    colorBg      String
    createdAt    DateTime @default(now())
}

model LogoPreset {
    id        String   @id @default(cuid())
    name      String
    imageUrl  String
    createdAt DateTime @default(now())
}

model OfferConfig {
    id            String    @id @default(cuid())
    offerId       String    @unique
    offerName     String
    whitelisted   Boolean   @default(false)
    imageUrl      String?
    notes         String?
    appStackId    String?
    appStack      AppStack? @relation(fields: [appStackId], references: [id], onDelete: SetNull)
    // Paquete completo que arrastra la oferta al crear campaña (autocompletado):
    colorPresetId String?   // → ColorPreset (colores)
    logoPresetId  String?   // → LogoPreset (logo)
    domain        String?   // root domain donde se publican las campañas de esta oferta
    fontTitle     String?   // fuente de títulos (ej. "Manrope")
    fontBody      String?   // fuente de párrafos (ej. "Inter")
    appIds        String[]  @default([]) // apps sueltas del directorio (alternativa al stack)
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    @@index([whitelisted])
    @@index([appStackId])
}

// Directorio/librería de apps sueltas (dedup de los stacks + agregadas a mano).
// Se usan en ofertas que no van con un stack entero (ej. teststar, empfohlen).
model App {
    id        String   @id @default(cuid())
    name      String
    imageUrl  String?
    tag       String   @default("1 hr")
    badge     String   @default("TOP")
    amount    Float    @default(0)
    createdAt DateTime @default(now())
}

model AppStack {
    id        String         @id @default(cuid())
    name      String
    items     AppStackItem[]
    offers    OfferConfig[]
    createdAt DateTime       @default(now())
    updatedAt DateTime       @updatedAt
}

model AppStackItem {
    id       String   @id @default(cuid())
    stackId  String
    stack    AppStack @relation(fields: [stackId], references: [id], onDelete: Cascade)
    name     String
    imageUrl String?
    tag      String   @default("1 hr")
    badge    String   @default("TOP")
    amount   Float
    position Int      @default(0)
    createdAt DateTime @default(now())

    @@index([stackId, position])
}

model AppConfig {
    key       String   @id
    value     String
    updatedAt DateTime @updatedAt
}

model ChatMessage {
    id        String   @id @default(cuid())
    userId    String
    username  String
    text      String
    createdAt DateTime @default(now())

    @@index([createdAt])
}

model Conversion {
    id           String   @id @default(cuid())
    price        Float    @default(0)
    offerName    String?
    country      String?
    s1           String?
    s2           String?
    clickId      String?
    conversionId String?
    ip           String?
    receivedAt   DateTime @default(now())

    @@index([receivedAt])
    @@index([s1])
}

// Click al CTA de una landing (s1 = slug de la campaña), para métricas por campaña.
model Click {
    id        String   @id @default(cuid())
    s1        String
    ip        String?
    createdAt DateTime @default(now())

    @@index([s1])
    @@index([createdAt])
}
