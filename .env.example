# Supabase PostgreSQL
# DATABASE_URL = Transaction mode (puerto 6543, con pgbouncer=true)
# DIRECT_URL   = Conexión directa (puerto 5432, para migraciones)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase — panel Settings > API
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# TapRain API — dashboard > Developer
TAPRAIN_API_KEY="your_taprain_api_key"
TAPRAIN_USER_ID="your_taprain_user_id"

# Secreto del postback: si lo definís, /api/postback exige ?secret=<este valor>.
# Agregá &secret=<valor> a la Global Postback URL en TapRain. Evita conversiones falsas.
POSTBACK_SECRET=""

# SMM World API — dashboard > API (tab Interacciones)
SMM_KEY="your_smmworld_api_key"

# TapRain Ads Suite (Tarjetas/VCCs) — session-auth.
# La cookie de sesión se guarda en DB y se pega desde /cards (no requiere redeploy).
# Opcional: cookie por defecto via env (fallback).
TAPRAIN_SUITE_BASE="https://taprain.com"
TAPRAIN_SUITE_COOKIE=""

# Bootstrap del primer admin (OPCIONAL — solo para crear el admin inicial).
# /api/admin-setup?token=ADMIN_SETUP_TOKEN crea el admin SOLO si no existe ninguno.
# Dejalos vacíos en prod una vez creado el admin (la ruta queda deshabilitada).
ADMIN_SETUP_TOKEN=""
ADMIN_SETUP_USERNAME=""
ADMIN_SETUP_PASSWORD=""

NEXTAUTH_SECRET="generate_a_random_secret"
# En el VPS: NEXTAUTH_URL debe ser la URL del panel (ej. https://app.tapsur.com)
NEXTAUTH_URL="http://localhost:3000"

# ─── Hosting de landings por dominio (self-host / VPS) ───
# APP_HOST: dominio del PANEL (ej. app.tapsur.com). Vacío → todo es el panel.
APP_HOST=""
# LANDING_BASE: <slug>.LANDING_BASE sirve la landing de ese slug (ej. tapsur.com → uk-marzo.tapsur.com).
LANDING_BASE=""
# LANDING_DOMAINS: DEPRECADO. El mapeo dominio custom → campaña ahora vive en la DB
# y se administra desde el panel (Admin → Dominios). Ya no hace falta tocar el .env.
LANDING_DOMAINS="{}"
