# Supabase PostgreSQL
# DATABASE_URL = Transaction mode (puerto 6543, con pgbouncer=true)
# DIRECT_URL   = Conexión directa (puerto 5432, para migraciones)
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase — panel Settings > API
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# TapRain API — dashboard > Developer
TAPRAIN_API_KEY="your_taprain_api_key"
TAPRAIN_USER_ID="your_taprain_user_id"

NEXTAUTH_SECRET="generate_a_random_secret"
